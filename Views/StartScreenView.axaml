<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OthelloAI.ViewModels"
             x:Class="OthelloAI.Views.StartScreenView"
             x:DataType="vm:StartScreenViewModel">

    <Grid Background="{DynamicResource MainBg}">
        <Border Background="{DynamicResource CardBg}" 
                CornerRadius="20" 
                Padding="50, 40"
                Width="420"
                HorizontalAlignment="Center" 
                VerticalAlignment="Center"
                BoxShadow="0 8 24 0 #26000000">
            
            <StackPanel Spacing="20">
                <StackPanel Spacing="10" HorizontalAlignment="Center" Margin="0,0,0,10">
                    <TextBlock Text="OTHELLO AI"
                               FontSize="28" 
                               FontWeight="Bold" 
                               LetterSpacing="2"
                               Foreground="{DynamicResource TextMain}" 
                               HorizontalAlignment="Center"/>
                    
                    <Border Height="3" Width="50" Background="{DynamicResource LightPiece}" CornerRadius="2"/>
                </StackPanel>

                <StackPanel Spacing="10">
                    <TextBlock Text="Choose your color:" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource TextMain}"/>
                    <StackPanel Orientation="Horizontal" Spacing="30">
                        <RadioButton GroupName="Color" Content="Dark (First)" IsChecked="{Binding IsDarkColorSelected}" Foreground="{DynamicResource TextMain}"/>
                        <RadioButton GroupName="Color" Content="Light (Second)" Foreground="{DynamicResource TextMain}"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Spacing="10">
                    <TextBlock Text="Time per game (minutes):" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource TextMain}"/>
                    <ComboBox HorizontalAlignment="Stretch" SelectedIndex="{Binding SelectedTimeIndex}" CornerRadius="8" Background="{DynamicResource MainBg}">
                        <ComboBoxItem>10</ComboBoxItem>
                        <ComboBoxItem>20</ComboBoxItem>
                        <ComboBoxItem>30</ComboBoxItem>
                    </ComboBox>
                </StackPanel>

                <StackPanel Spacing="10" Margin="0,0,0,10">
                    <TextBlock Text="AI Difficulty:" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource TextMain}"/>
                    <ComboBox HorizontalAlignment="Stretch" SelectedIndex="{Binding SelectedDifficultyIndex}" CornerRadius="8" Background="{DynamicResource MainBg}">
                        <ComboBoxItem>Novice (Depth 2)</ComboBoxItem>
                        <ComboBoxItem>Master (Depth 4)</ComboBoxItem>
                        <ComboBoxItem>Grandmaster (Depth 6)</ComboBoxItem>
                        <ComboBoxItem>Impossible (Depth 8)</ComboBoxItem>
                    </ComboBox>
                </StackPanel>

                <Button Command="{Binding StartGameCommand}"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Background="{DynamicResource DarkPiece}"
                        Foreground="#FFFFFF"
                        FontSize="16"
                        FontWeight="Bold"
                        CornerRadius="8"
                        Padding="15"
                        Margin="0, 10, 0, 0">
                    <TextBlock Text="START GAME" />
                </Button>

            </StackPanel>
        </Border>
    </Grid>
</UserControl>
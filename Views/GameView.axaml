<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OthelloAI.ViewModels"
             x:Class="OthelloAI.Views.GameView"
             x:DataType="vm:GameViewModel"
             x:Name="GameRoot">

    <Grid Background="{DynamicResource MainBg}">
        
        <Grid ColumnDefinitions="Auto, 100, Auto" HorizontalAlignment="Center" VerticalAlignment="Center">
            
            <StackPanel Grid.Column="0" Spacing="30">
                
                <StackPanel Spacing="5">
                    <TextBlock Text="Othello AI" FontSize="32" FontWeight="Heavy" Foreground="{DynamicResource TextMain}"/>
                    <TextBlock Text="A minute to learn, a lifetime to master" FontSize="14" Foreground="{DynamicResource TextMuted}"/>
                </StackPanel>

                <Border BorderBrush="{DynamicResource LineColor}" BorderThickness="1">
                    <ItemsControl ItemsSource="{Binding BoardCells}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Rows="8" Columns="8" Width="400" Height="400" Background="{DynamicResource LineColor}"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:CellViewModel">
                                <Button Command="{Binding $parent[UserControl].((vm:GameViewModel)DataContext).CellClickedCommand}"
                                        CommandParameter="{Binding}"
                                        Background="{DynamicResource CardBg}"
                                        Margin="0.5"
                                        CornerRadius="0"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch">
                                    <Grid>
                                        <Ellipse Width="35" Height="35" IsVisible="{Binding HasPiece}"
                                                 Classes.dark="{Binding IsDark}"
                                                 Classes.light="{Binding IsLight}">
                                            <Ellipse.Styles>
                                                <Style Selector="Ellipse.dark"><Setter Property="Fill" Value="{DynamicResource DarkPiece}"/></Style>
                                                <Style Selector="Ellipse.light"><Setter Property="Fill" Value="{DynamicResource LightPiece}"/></Style>
                                            </Ellipse.Styles>
                                        </Ellipse>

                                        <Ellipse Width="12" Height="12" 
                                                 Fill="{DynamicResource TextMain}" 
                                                 Opacity="0.3"
                                                 IsVisible="{Binding IsValidMove}"
                                                 HorizontalAlignment="Center" 
                                                 VerticalAlignment="Center"/>   
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>
            </StackPanel>

            <StackPanel Grid.Column="2" Spacing="40" VerticalAlignment="Center">
                
                <Border BorderBrush="{DynamicResource LineColor}" BorderThickness="1">
                    <Grid RowDefinitions="50, 50" ColumnDefinitions="80, 150, 60, 60" Background="{DynamicResource LineColor}">
                        
                        <Border Grid.Row="0" Grid.Column="0" Background="{DynamicResource CardBg}" Margin="0,0,1,1">
                            <TextBlock Text="Turn" FontWeight="Bold" Foreground="{DynamicResource TextMain}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Border Grid.Row="0" Grid.Column="1" Background="{DynamicResource CardBg}" Margin="0,0,1,1">
                            <TextBlock Text="Remaining Time" FontWeight="Bold" Foreground="{DynamicResource TextMain}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Border Grid.Row="0" Grid.Column="2" Background="{DynamicResource CardBg}" Margin="0,0,1,1">
                            <Ellipse Width="24" Height="24" Fill="{DynamicResource DarkPiece}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Border Grid.Row="0" Grid.Column="3" Background="{DynamicResource CardBg}" Margin="0,0,0,1">
                            <Ellipse Width="24" Height="24" Fill="{DynamicResource LightPiece}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <Border Grid.Row="1" Grid.Column="0" Background="{DynamicResource CardBg}" Margin="0,0,1,0">
                            <Ellipse Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center"
                                     Classes.dark="{Binding IsDarkTurn}"
                                     Classes.light="{Binding IsLightTurn}">
                                <Ellipse.Styles>
                                    <Style Selector="Ellipse.dark"><Setter Property="Fill" Value="{DynamicResource DarkPiece}"/></Style>
                                    <Style Selector="Ellipse.light"><Setter Property="Fill" Value="{DynamicResource LightPiece}"/></Style>
                                </Ellipse.Styles>
                            </Ellipse>
                        </Border>
                        <Border Grid.Row="1" Grid.Column="1" Background="{DynamicResource CardBg}" Margin="0,0,1,0">
                            <TextBlock Text="{Binding TimeRemaining}" Foreground="{DynamicResource TextMain}" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Border Grid.Row="1" Grid.Column="2" Background="{DynamicResource CardBg}" Margin="0,0,1,0">
                            <TextBlock Text="{Binding BlackScore}" FontSize="24" FontWeight="Heavy" Foreground="{DynamicResource TextMain}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Border Grid.Row="1" Grid.Column="3" Background="{DynamicResource CardBg}">
                            <TextBlock Text="{Binding WhiteScore}" FontSize="24" FontWeight="Heavy" Foreground="{DynamicResource TextMain}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <Border BorderBrush="{DynamicResource LineColor}" BorderThickness="1" Height="300">
                    <Grid RowDefinitions="60, *" ColumnDefinitions="*, *" Background="{DynamicResource LineColor}">
                        
                        <Border Grid.Row="0" Grid.Column="0" Background="{DynamicResource CardBg}" Margin="0,0,1,1">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10">
                                <TextBlock Text="You" FontWeight="Bold" Foreground="{DynamicResource TextMain}" VerticalAlignment="Center"/>
                                
                                <Ellipse Width="20" Height="20"
                                         Classes.dark="{Binding IsHumanDark}"
                                         Classes.light="{Binding IsHumanLight}">
                                    <Ellipse.Styles>
                                        <Style Selector="Ellipse.dark"><Setter Property="Fill" Value="{DynamicResource DarkPiece}"/></Style>
                                        <Style Selector="Ellipse.light"><Setter Property="Fill" Value="{DynamicResource LightPiece}"/></Style>
                                    </Ellipse.Styles>
                                </Ellipse>
                            </StackPanel>
                        </Border>
                        
                        <Border Grid.Row="0" Grid.Column="1" Background="{DynamicResource CardBg}" Margin="0,0,0,1">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10">
                                <TextBlock Text="AI" FontWeight="Bold" Foreground="{DynamicResource TextMain}" VerticalAlignment="Center"/>
                                
                                <Ellipse Width="20" Height="20"
                                         Classes.dark="{Binding IsAIDark}"
                                         Classes.light="{Binding IsAILight}">
                                    <Ellipse.Styles>
                                        <Style Selector="Ellipse.dark"><Setter Property="Fill" Value="{DynamicResource DarkPiece}"/></Style>
                                        <Style Selector="Ellipse.light"><Setter Property="Fill" Value="{DynamicResource LightPiece}"/></Style>
                                    </Ellipse.Styles>
                                </Ellipse>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1" Grid.Column="0" Background="{DynamicResource CardBg}" Margin="0,0,1,0" Padding="10">
                            <ScrollViewer>
                                <ItemsControl ItemsSource="{Binding PlayerMoves}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" Foreground="{DynamicResource TextMain}" FontSize="16" HorizontalAlignment="Center" Margin="0,5"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>
                        
                        <Border Grid.Row="1" Grid.Column="1" Background="{DynamicResource CardBg}" Padding="10">
                            <ScrollViewer>
                                <ItemsControl ItemsSource="{Binding AIMoves}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" Foreground="{DynamicResource TextMain}" FontSize="16" HorizontalAlignment="Center" Margin="0,5"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Border>

            </StackPanel>
        </Grid>
        
        <Grid Background="#CC181B22" IsVisible="{Binding IsGameOver}">
            
            <Border Background="{DynamicResource CardBg}"
                    CornerRadius="20"
                    Padding="60, 40"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    BoxShadow="0 10 30 0 #40000000"> 
                <StackPanel Spacing="30" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding GameOverMessage}" 
                               FontSize="48" 
                               FontWeight="Heavy" 
                               Foreground="{DynamicResource TextMain}" 
                               HorizontalAlignment="Center"/>
                    
                    <StackPanel Orientation="Horizontal" Spacing="20" HorizontalAlignment="Center">
                        <TextBlock Text="Final Score:" FontSize="24" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                        <Ellipse Width="24" Height="24" Fill="{DynamicResource DarkPiece}"/>
                        <TextBlock Text="{Binding BlackScore}" FontSize="32" FontWeight="Bold" Foreground="{DynamicResource TextMain}"/>
                        <TextBlock Text="-" FontSize="32" FontWeight="Bold" Foreground="{DynamicResource TextMuted}"/>
                        <TextBlock Text="{Binding WhiteScore}" FontSize="32" FontWeight="Bold" Foreground="{DynamicResource TextMain}"/>
                        <Ellipse Width="24" Height="24" Fill="{DynamicResource LightPiece}"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="20" HorizontalAlignment="Center">
                        <Button Content="Play Again"
                                Command="{Binding RestartCommand}"
                                Width="160"
                                HorizontalContentAlignment="Center"
                                Background="{DynamicResource LightPiece}"
                                Foreground="#FFFFFF"
                                FontSize="18"
                                FontWeight="Bold"
                                CornerRadius="8"
                                Padding="15"/>

                        <Button Content="Quit Game"
                                Command="{Binding QuitCommand}"
                                Width="160"
                                HorizontalContentAlignment="Center"
                                Background="{DynamicResource LightPiece}"
                                Foreground="#FFFFFF"
                                FontSize="18"
                                FontWeight="Bold"
                                CornerRadius="8"
                                Padding="15"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
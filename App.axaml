<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="OthelloAI.App"
             RequestedThemeVariant="Light">

    <Application.Styles>
        <FluentTheme />
    </Application.Styles>

    <Application.Resources>
        <SolidColorBrush x:Key="MainBg">#F2F4F7</SolidColorBrush>   <SolidColorBrush x:Key="CardBg">#E5E8EC</SolidColorBrush>   <SolidColorBrush x:Key="WhiteBg">#FFFFFF</SolidColorBrush>  <SolidColorBrush x:Key="LineColor">#A1A9B7</SolidColorBrush> 
        
        <SolidColorBrush x:Key="DarkPiece">#181B22</SolidColorBrush>
        <SolidColorBrush x:Key="LightPiece">#259DA6</SolidColorBrush>
        
        <SolidColorBrush x:Key="TextMain">#181B22</SolidColorBrush>
        <SolidColorBrush x:Key="TextMuted">#7A828F</SolidColorBrush>
    </Application.Resources>

</Application>